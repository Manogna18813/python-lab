file = open("seek_example.txt", "w+")
file.write("Python File Handling Example")
file.flush()
print("Current position after write:", file.tell())
file.seek(18)
print("Position after seek(0):", file.tell())
print("Reading from beginning:", file.read(10))
file.seek(4)
print("Position after seek(7):", file.tell())
print("Reading from position 7:", file.read(11))
